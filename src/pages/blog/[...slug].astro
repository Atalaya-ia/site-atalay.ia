---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { articles } from '../../data/articles';

// ── Static paths for SSG ──
export function getStaticPaths() {
  return Object.keys(articles).map(slug => ({ params: { slug } }));
}

// ── Route logic ──
const { slug } = Astro.params;
const article = slug ? articles[slug] : undefined;

if (!article) {
  return Astro.redirect('/blog');
}

function formatDate(dateStr: string) {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' });
}

// Find next/prev articles
const slugs = Object.keys(articles);
const currentIndex = slugs.indexOf(slug!);
const nextSlug = currentIndex < slugs.length - 1 ? slugs[currentIndex + 1] : null;
const prevSlug = currentIndex > 0 ? slugs[currentIndex - 1] : null;
const nextArticle = nextSlug ? articles[nextSlug] : null;
const prevArticle = prevSlug ? articles[prevSlug] : null;

const articleUrl = `https://atalayia.com.br/blog/${slug}/`;
const publishedIso = `${article.date}T00:00:00-03:00`;

// Data de modificação real (quando links/traduções foram atualizados)
const modifiedDates: Record<string, string> = {
  'lancamento-atalay-ia': '2026-04-10',
  'como-ia-contextual-muda-jornalismo': '2026-04-10',
  'pipeline-dados-editoriais': '2026-04-10',
  'voz-editorial-agentes': '2026-04-10',
  'discover-vs-busca': '2026-04-10',
  'manual-redacao-ia': '2026-04-10',
  'por-que-audiencia-jornal-cai': '2026-04-10',
  'caso-nyt-ia-redacao': '2026-04-10',
  'como-levar-ia-para-redacao': '2026-04-10',
  'ia-ferramenta-ou-ameaca-jornalismo': '2026-04-10',
  'google-discover-trafico-redacoes': '2026-04-10',
  'o-que-e-eeat': '2026-04-10',
  'o-que-e-ymyl': '2026-04-10',
  'google-discover-core-update-fevereiro-2026': '2026-04-10',
  'google-spam-update-reescrita-titulos-ia': '2026-04-10',
  'anthropic-vaza-codigo-claude-code': '2026-04-10',
  'anthropic-conter-vazamento-claude-code': '2026-04-10',
  'nyt-rompe-colaborador-ia-resenha': '2026-04-10',
  'llms-txt-arquitetura-marca-fonte-ia': '2026-04-10',
  'bimbofication-google-trends-kristi-noem': '2026-04-10',
  'anthropic-libera-mythos-apple-ciberataques': '2026-04-10',
  'openai-crises-trocas-comando-pressao-lucro': '2026-04-10',
  'neuralink-chips-cerebrais-fala': '2026-04-13',
  'google-news-polymarket-apostas-noticia': '2026-04-13',
  'openai-apoia-projeto-blindar-ia-tragedias': '2026-04-13',
  'mulher-processa-openai-chatgpt-stalker': '2026-04-16',
  'ia-enfraquece-raciocinio-estudo': '2026-04-16',
  'starbucks-chatgpt-escolher-cafe': '2026-04-16',
  'gpt-5-5-vs-claude-opus-4-7-comparativo': '2026-04-25',
  'humanizar-texto-ia-sinceerly-gmail': '2026-04-25',
};
const modifiedDate = modifiedDates[slug!] || article.date;
const modifiedIso = `${modifiedDate}T00:00:00-03:00`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: article.title,
    description: article.description,
    datePublished: publishedIso,
    dateModified: modifiedIso,
    url: articleUrl,
    mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
    inLanguage: 'pt-BR',
    articleSection: article.category,
    author: {
      '@type': 'Person',
      name: article.author,
      jobTitle: article.role,
      url: 'https://atalayia.com.br/autor/bruno-lopes/',
      image: 'https://atalayia.com.br/autores/bruno-lopes.png',
      sameAs: ['https://www.linkedin.com/in/bruno-olopes/'],
    },
    publisher: {
      '@type': 'Organization',
      name: 'Atalay.ia',
      url: 'https://atalayia.com.br',
      logo: {
        '@type': 'ImageObject',
        url: 'https://atalayia.com.br/og-image.png',
      },
    },
    image: {
      '@type': 'ImageObject',
      url: `https://atalayia.com.br/og/${slug}.png`,
      width: 1200,
      height: 600,
    },
  },
];
---
<Base
  title={`${article.title} — Atalay.ia`}
  description={article.description}
  url={articleUrl}
  ogType="article"
  image={`https://atalayia.com.br/og/${slug}.png`}
  publishedTime={publishedIso}
  modifiedTime={modifiedIso}
  author={article.author}
  jsonLd={jsonLd}
>
  <Nav />

  <article class="post">
    <div class="post-wrap">

      <!-- Hero image -->
      <figure class="post-hero">
        <img
          src={`/og/${slug}.png`}
          alt={article.title}
          width="1200"
          height="600"
          loading="eager"
          decoding="async"
        />
        <figcaption>
          <span class="post-hero-desc">{article.description}</span>
          <span class="post-hero-credit">Ilustração: {article.author}</span>
        </figcaption>
      </figure>

      <!-- Header -->
      <header class="post-header">
        <div class="post-meta">
          <span class="post-cat">{article.category}</span>
          <span class="post-date">{formatDate(article.date)}</span>
          <span class="post-read">{article.readTime} de leitura</span>
        </div>
        <h1 class="post-title">{article.title}</h1>
        <p class="post-desc">{article.description}</p>
        <a href="/autor/bruno-lopes/" class="post-author">
          <img src="/autores/bruno-lopes.png" alt={article.author} class="post-author-avatar" width="44" height="44" loading="lazy" />
          <div>
            <div class="post-author-name">{article.author}</div>
            <div class="post-author-role">{article.role}</div>
          </div>
        </a>
      </header>

      <!-- Divider -->
      <div class="post-divider"></div>

      <!-- Body -->
      <div class="post-body" set:html={article.content} />

      <!-- Navigation -->
      <div class="post-nav">
        {prevArticle && prevSlug && (
          <a href={`/blog/${prevSlug}`} class="post-nav-link post-nav-prev">
            <span class="post-nav-label">Anterior</span>
            <span class="post-nav-title">{prevArticle.title}</span>
          </a>
        )}
        {nextArticle && nextSlug && (
          <a href={`/blog/${nextSlug}`} class="post-nav-link post-nav-next">
            <span class="post-nav-label">Próximo</span>
            <span class="post-nav-title">{nextArticle.title}</span>
          </a>
        )}
      </div>

      <!-- CTA -->
      <div class="post-cta">
        <p class="post-cta-text">Quer ver o atalay.ia na sua redação?</p>
        <a href="/contato" class="post-cta-btn">Solicitar demonstração</a>
      </div>

    </div>
  </article>

  <Footer />

  <!-- article_read: 75% scroll OR 30s on page -->
  <script define:vars={{ articleId: slug, articleCategory: article.category, articleAuthor: article.author, articleDate: article.date }}>
    (function() {
      var fired = false;
      function fire() {
        if (fired) return;
        fired = true;
        try {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: 'article_read',
            article_id: articleId,
            category: articleCategory,
            author: articleAuthor,
            publish_date: articleDate
          });
        } catch(e) {}
      }
      // 30s timer
      var timer = setTimeout(fire, 30000);
      // 75% scroll
      function checkScroll() {
        var scrolled = window.scrollY + window.innerHeight;
        var total = document.documentElement.scrollHeight;
        if (scrolled / total >= 0.75) {
          fire();
          window.removeEventListener('scroll', checkScroll);
          clearTimeout(timer);
        }
      }
      window.addEventListener('scroll', checkScroll, { passive: true });
    })();
  </script>
</Base>

<style is:global>
  /* ── Article page ── */
  .post {
    padding: 120px 0 80px;
  }

  .post-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Hero */
  .post-hero {
    margin: 0 0 40px;
    padding: 0;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .post-hero img {
    display: block;
    width: 100%;
    height: auto;
  }

  .post-hero figcaption {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 10px 16px;
    background: rgba(255,255,255,.02);
    border-top: 1px solid var(--border);
  }

  .post-hero-desc {
    font-size: .75rem;
    color: var(--muted);
    line-height: 1.4;
    flex: 1;
  }

  .post-hero-credit {
    font-size: .7rem;
    color: var(--muted);
    opacity: .6;
    white-space: nowrap;
  }

  /* Header */
  .post-header {
    margin-bottom: 40px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .post-cat {
    font-size: 12px;
    font-weight: 600;
    color: var(--orange);
    text-transform: uppercase;
    letter-spacing: .8px;
  }

  .post-date,
  .post-read {
    font-size: 14px;
    color: var(--text-m);
  }

  .post-title {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -.03em;
    margin-bottom: 20px;
    color: var(--text);
  }

  .post-desc {
    font-size: 19px;
    line-height: 1.6;
    color: var(--text-s);
    margin-bottom: 32px;
  }

  .post-author {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    transition: opacity .2s;
  }

  .post-author:hover {
    opacity: .8;
  }

  .post-author-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border-l);
    flex-shrink: 0;
  }

  .post-author-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }

  .post-author-role {
    font-size: 13px;
    color: var(--text-m);
  }

  /* Divider */
  .post-divider {
    height: 1px;
    background: var(--border);
    margin-bottom: 48px;
  }

  /* Body */
  .post-body {
    font-size: 17px;
    line-height: 1.75;
    color: var(--text-s);
  }

  .post-body .article-lead {
    font-size: 20px;
    line-height: 1.65;
    color: var(--text);
    margin-bottom: 28px;
  }

  .post-body p {
    margin-bottom: 24px;
  }

  .post-body h2 {
    font-family: 'Instrument Serif', serif;
    font-size: 28px;
    font-weight: 400;
    letter-spacing: -.02em;
    color: var(--text);
    margin-top: 56px;
    margin-bottom: 20px;
  }

  .post-body h3 {
    font-size: 18px;
    font-weight: 600;
    color: var(--text);
    margin-top: 40px;
    margin-bottom: 14px;
  }

  .post-body strong {
    color: var(--text);
    font-weight: 600;
  }

  .post-body em {
    font-style: italic;
  }

  .post-body a {
    color: var(--orange);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(192,106,66,.3);
    transition: text-decoration-color .2s;
  }

  .post-body a:hover {
    text-decoration-color: var(--orange);
  }

  .post-body ul {
    margin-bottom: 24px;
    padding-left: 0;
    list-style: none;
  }

  .post-body ul li {
    position: relative;
    padding-left: 24px;
    margin-bottom: 12px;
  }

  .post-body ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 11px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--orange);
    opacity: .5;
  }

  .post-body figure {
    margin: 36px 0;
    padding: 0;
  }

  .post-body figure img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 10px;
    border: 1px solid var(--border);
  }

  .post-body figcaption {
    margin-top: 10px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-m);
    text-align: center;
  }

  .post-body blockquote {
    margin: 40px 0;
    padding: 24px 28px;
    border-left: 3px solid var(--orange);
    background: rgba(192,106,66,.04);
    border-radius: 0 12px 12px 0;
  }

  .post-body blockquote p {
    font-size: 18px;
    font-style: italic;
    line-height: 1.65;
    color: var(--text);
    margin-bottom: 0;
  }

  /* Navigation between posts */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 64px;
    padding-top: 40px;
    border-top: 1px solid var(--border);
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color .2s, background .2s;
  }

  .post-nav-link:hover {
    border-color: var(--border-h);
    background: rgba(255,255,255,.02);
  }

  .post-nav-next {
    text-align: right;
    grid-column: 2;
  }

  .post-nav-label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .8px;
    color: var(--text-m);
  }

  .post-nav-title {
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* CTA */
  .post-cta {
    margin-top: 48px;
    padding: 36px;
    border-radius: 16px;
    background: rgba(192,106,66,.04);
    border: 1px solid rgba(192,106,66,.12);
    text-align: center;
  }

  .post-cta-text {
    font-size: 18px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 16px;
  }

  .post-cta-btn {
    display: inline-block;
    padding: 12px 28px;
    background: rgba(192,106,66,.15);
    color: var(--orange);
    border: 1px solid rgba(192,106,66,.25);
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    font-family: 'DM Sans', sans-serif;
    text-decoration: none;
    transition: background .2s, border-color .2s;
  }

  .post-cta-btn:hover {
    background: rgba(192,106,66,.22);
    border-color: rgba(192,106,66,.35);
  }

  /* Mobile */
  @media (max-width: 767px) {
    .post { padding: 100px 0 60px }
    .post-wrap { padding: 0 20px }
    .post-hero { margin-bottom: 28px }
    .post-title { font-size: 28px }
    .post-desc { font-size: 17px }
    .post-body { font-size: 16px }
    .post-body .article-lead { font-size: 18px }
    .post-body h2 { font-size: 24px; margin-top: 40px }
    .post-body blockquote { padding: 20px 22px }
    .post-nav { grid-template-columns: 1fr; }
    .post-nav-next { text-align: left; grid-column: 1 }
    .post-cta { padding: 28px 24px }
  }
</style>
