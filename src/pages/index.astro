---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ProofBar from '../components/ProofBar.astro';
import Values from '../components/Values.astro';
import FeatureSection from '../components/FeatureSection.astro';
import OptimizeSidebar from '../components/sidebars/OptimizeSidebar.astro';
import TrendsSidebar from '../components/sidebars/TrendsSidebar.astro';
import VoiceSidebar from '../components/sidebars/VoiceSidebar.astro';
import Pipeline from '../components/Pipeline.astro';
import CtaSection from '../components/CtaSection.astro';
import Footer from '../components/Footer.astro';
---
<Base
  title="Atalay.ia — Inteligência editorial para redações"
  description="Copiloto editorial com IA para redações. Otimize títulos, detecte tendências e mantenha a voz de cada jornalista."
>
  <Nav />
  <Hero />
  <ProofBar />
  <Values />

  <FeatureSection
    id="optimize"
    title="Da pauta à publicação, sem retrabalho"
    description="Revisão automática de título, imagem, estrutura e SEO — calibrada pelo Manual de Redação e pelos dados reais do seu domínio. Cada sugestão respeita as regras da sua redação, não de um modelo genérico."
    linkLabel="1.0 Optimize"
    linkHref="#optimize"
    stats={[
      { value: "85%", label: "menos tempo de edição" },
      { value: "7", label: "campos por matéria" },
      { value: "100%", label: "revisão humana" }
    ]}
    items={[
      { title: "Reescrita completa", description: "Título editorial, SEO, descrição, meta, corpo, tags e sugestão de imagem — na voz do jornalista", iconSvg: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>' },
      { title: "Correção gramatical", description: "Gramática e Manual de Redação com marcações inline clicáveis", iconSvg: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>' },
      { title: "Revisão HTML", description: "Schema, Open Graph, alt em imagens, headings — checklist técnico", iconSvg: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"><path d="M16 18l2-2-2-2"/><path d="M8 6L6 8l2 2"/><line x1="12" y1="2" x2="12" y2="22"/></svg>' },
      { title: "Avaliação de imagem", description: "Classificadores binários com recomendação baseada em dados de CTR", iconSvg: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>' }
    ]}
    subs={[
      { num: "1.1", label: "Reescrita" },
      { num: "1.2", label: "Correção" },
      { num: "1.3", label: "Revisão HTML" },
      { num: "1.4", label: "Avaliação de imagem" }
    ]}
  >
    <OptimizeSidebar />
  </FeatureSection>

  <FeatureSection
    id="trends"
    title="Detecte oportunidades antes da concorrência publicar"
    description="Acompanhe o que está ganhando força na busca e no Discover — filtrado pelos assuntos em que sua redação já tem autoridade. Você publica primeiro, com contexto."
    linkLabel="2.0 Trends"
    linkHref="#trends"
    stats={[
      { value: "47min", label: "antes da concorrência" },
      { value: "3.2x", label: "mais tráfego Discover" },
      { value: "24/7", label: "monitoramento ativo" }
    ]}
    items={[
      { title: "Radar Discover", description: "O que os concorrentes estão ganhando de distribuição no Discover em tempo real", iconSvg: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>' },
      { title: "Tendências de Pesquisa", description: "Temas em alta com volume, velocidade de crescimento e potencial por editoria", iconSvg: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>' },
      { title: "Insight + Agente", description: "Um clique gera a matéria com o agente certo, na voz certa", iconSvg: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>' }
    ]}
    subs={[
      { num: "2.1", label: "Radar Discover" },
      { num: "2.2", label: "Tendências de Pesquisa" },
      { num: "2.3", label: "Insights Editoriais" }
    ]}
    flip={true}
  >
    <TrendsSidebar />
  </FeatureSection>

  <FeatureSection
    id="voice"
    title="Cada jornalista tem um agente que escreve como ele"
    description="A IA analisa como cada jornalista escreve — estilo, tom, estrutura — e aprende a gerar sugestões que soam como ele. Não é texto de robô. É a voz da redação."
    linkLabel="3.0 Voz editorial"
    linkHref="#voice"
    stats={[
      { value: "92%", label: "aderência à voz" },
      { value: "500+", label: "artigos por perfil" },
      { value: "<3s", label: "para gerar na voz" }
    ]}
    items={[
      { title: "Preferências declaradas", description: "Tom, citações, aderência ao manual — capturado via wizard guiado", iconSvg: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"><path d="M12 2a3 3 0 00-3 3v7a3 3 0 006 0V5a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>' },
      { title: "Análise de artigos reais", description: "Padrões de vocabulário, estrutura e vícios de escrita extraídos de centenas de publicações", iconSvg: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>' },
      { title: "Validação pelo jornalista", description: "\"Reconhece esse estilo?\" — a IA gera um sample e o jornalista confirma ou ajusta", iconSvg: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>' }
    ]}
    subs={[
      { num: "3.1", label: "Perfis de voz" },
      { num: "3.2", label: "Wizard de onboarding" },
      { num: "3.3", label: "Agentes por editoria" }
    ]}
  >
    <VoiceSidebar />
  </FeatureSection>

  <Pipeline />
  <CtaSection />
  <Footer />
</Base>
