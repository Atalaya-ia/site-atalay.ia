---
interface Props {
  id: string;
  title: string;
  description: string;
  linkLabel: string;
  linkHref: string;
  stats: { value: string; label: string }[];
  items: { title: string; description: string; iconSvg: string }[];
  subs: { num: string; label: string }[];
  flip?: boolean;
}
const { id, title, description, linkLabel, linkHref, stats, items, subs, flip = false } = Astro.props;
---
<section class="feat section-border" id={id}>
  <div class="wrap">
    <div class="feat-header reveal">
      <div class="feat-header-left">
        <h2 set:html={title} />
      </div>
      <div class="feat-header-right">
        <p>{description}</p>
        <a href={linkHref} class="feat-header-link"><span>{linkLabel.split(' ')[0]}</span> {linkLabel.split(' ').slice(1).join(' ')} &rarr;</a>
      </div>
    </div>
    <div class={`feat-row${flip ? ' flip' : ''} reveal`}>
      <div class="feat-content">
        <div class="feat-stats">
          {stats.map(stat => (
            <div class="feat-stat">
              <div class="feat-stat-v">{stat.value}</div>
              <div class="feat-stat-l">{stat.label}</div>
            </div>
          ))}
        </div>
        <div class="feat-items">
          {items.map(item => (
            <div class="feat-item">
              <div class="feat-item-icon">
                <Fragment set:html={item.iconSvg} />
              </div>
              <div>
                <h4>{item.title}</h4>
                <p>{item.description}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="feat-subs">
          {subs.map(sub => (
            <div class="feat-sub">
              <span class="feat-sub-num">{sub.num}</span>{sub.label}<span class="feat-sub-plus">+</span>
            </div>
          ))}
        </div>
      </div>
      <div class="feat-panel">
        <slot />
      </div>
    </div>
  </div>
</section>
