<nav id="nav">
  <div class="nav-inner">
    <a href="#" class="nav-logo">
      <div class="nav-mark">A</div>
      <span class="nav-wm">Atalaya<span style="font-style:italic;color:var(--orange);opacity:0.8">.ia</span></span>
    </a>
    <button class="nav-hamburger" id="nav-toggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-links" id="nav-links">
      <a href="#optimize">Optimize</a>
      <a href="#trends">Trends</a>
      <a href="#voice">Voz</a>
      <a href="#pipeline">Pipeline</a>
      <a href="#contact" class="nav-cta">Solicitar Demo</a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle');
  const links = document.getElementById('nav-links');
  if (toggle && links) {
    toggle.addEventListener('click', () => {
      links.classList.toggle('open');
      toggle.classList.toggle('open');
    });
    // Close menu on link click
    links.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        links.classList.remove('open');
        toggle.classList.remove('open');
      });
    });
  }
</script>
