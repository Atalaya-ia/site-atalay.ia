<!-- Trends sidebar -->
<div class="sb">
  <div class="sb-hd">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--p-orange)" stroke-width="2" stroke-linecap="round">
      <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
    </svg>
    Trends
    <div style="margin-left:auto;display:flex;align-items:center;gap:4px">
      <div style="width:4px;height:4px;border-radius:50%;background:var(--p-green);animation:pulse-dot 2s infinite"></div>
      <span style="font-size:9px">Monitorando</span>
    </div>
  </div>
  <div class="sb-bd">
    <!-- Radar Discover zone -->
    <div class="tc-zone">
      <span class="tc-zone-dot" style="background:var(--p-orange)"></span>
      Radar Discover
    </div>

    <!-- Card 1: Copa do Brasil -->
    <div class="tc sel" onclick="tSel(this)">
      <div class="tc-top">
        <div class="tc-thumb" style="background:linear-gradient(135deg,#1e2228,#141618)">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--p-text-m)" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
          </svg>
        </div>
        <div>
          <div class="tc-title">Copa do Brasil 2026</div>
          <div class="tc-meta">
            <span class="tc-growth">+340%</span>
            <span class="tc-time">2h</span>
          </div>
        </div>
      </div>
      <div class="tc-insight">180K+ buscas. Vantagem editorial em Esportes.</div>
      <div class="tc-cta">
        <button class="tc-cta-btn" onclick="event.stopPropagation();if(typeof showToast==='function')showToast('Matéria criada com agente Rafael Santos')">Gerar matéria com agente</button>
      </div>
    </div>

    <!-- Card 2: Reforma tributária -->
    <div class="tc" onclick="tSel(this)">
      <div class="tc-top">
        <div class="tc-thumb" style="background:linear-gradient(135deg,#22201a,#141210)">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--p-text-m)" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <path d="M3 9h18"/>
          </svg>
        </div>
        <div>
          <div class="tc-title">Reforma tributária 2026</div>
          <div class="tc-meta">
            <span class="tc-growth">+180%</span>
            <span class="tc-time">25min</span>
          </div>
        </div>
      </div>
      <div class="tc-insight">Economia é território de autoridade do seu jornal.</div>
      <div class="tc-cta">
        <button class="tc-cta-btn" onclick="event.stopPropagation();if(typeof showToast==='function')showToast('Matéria criada com agente Ana Lima')">Gerar matéria com agente</button>
      </div>
    </div>

    <!-- Tendências de Pesquisa zone -->
    <div class="tc-zone" style="margin-top:4px;padding-top:8px;border-top:1px solid var(--p-border)">
      <span class="tc-zone-dot" style="background:#6e8999"></span>
      Tendências de Pesquisa
    </div>

    <!-- Card 3: Apagão em São Paulo -->
    <div class="tc" onclick="tSel(this)">
      <div class="tc-top">
        <div class="tc-thumb" style="background:linear-gradient(135deg,#1e1a28,#14101e)">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--p-text-m)" stroke-width="1.5">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
        </div>
        <div>
          <div class="tc-title">Apagão em São Paulo</div>
          <div class="tc-meta">
            <span class="tc-growth">+520%</span>
            <span class="tc-time">45min</span>
            <span style="font-size:8px;padding:1px 4px;border-radius:3px;background:rgba(248,113,113,.08);color:#f87171;font-weight:600">Urgente</span>
          </div>
        </div>
      </div>
      <div class="tc-insight">320K buscas. Cidades pode capturar tráfego regional.</div>
      <div class="tc-cta">
        <button class="tc-cta-btn" onclick="event.stopPropagation();if(typeof showToast==='function')showToast('Matéria criada com agente Pedro Ferreira')">Gerar matéria com agente</button>
      </div>
    </div>

    <!-- Card 4: Greve dos bancários -->
    <div class="tc" onclick="tSel(this)">
      <div class="tc-top">
        <div class="tc-thumb" style="background:linear-gradient(135deg,#1a2218,#101810)">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--p-text-m)" stroke-width="1.5">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
          </svg>
        </div>
        <div>
          <div class="tc-title">Greve dos bancários</div>
          <div class="tc-meta">
            <span class="tc-growth">+95%</span>
            <span class="tc-time">3h</span>
          </div>
        </div>
      </div>
      <div class="tc-insight">Pauta regional forte. Histórico em Cidades.</div>
      <div class="tc-cta">
        <button class="tc-cta-btn" onclick="event.stopPropagation();if(typeof showToast==='function')showToast('Matéria criada com agente Carla Mendes')">Gerar matéria com agente</button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
function tSel(el) {
  const parent = el.closest('.sb-bd');
  if (!parent) return;
  parent.querySelectorAll('.tc').forEach(tc => tc.classList.remove('sel'));
  el.classList.add('sel');
}
</script>
