<script is:inline>
function thermClick(container, e) {
  const btn = e.target.closest('.vp-th');
  if (!btn) return;
  const btns = Array.from(container.querySelectorAll('.vp-th'));
  const idx = btns.indexOf(btn);
  btns.forEach((b, i) => { if (i <= idx) b.classList.add('on'); else b.classList.remove('on'); });
}
</script>
