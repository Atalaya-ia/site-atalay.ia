</div><div class="sb-footer"><button class="sf" onclick="acceptAll()">Aceitar tudo</button><button class="sf sf-main" onclick="copyAll(this)">Copiar matéria</button></div></div>

<script is:inline>
function toggleFC(el) {
  if (el.classList.contains('accepted')) return;
  el.classList.add('accepted');
  const s = el.querySelector('.fc-status');
  if (s) { s.textContent = 'Aceito'; s.classList.add('ok'); }
}
function acceptAll() {
  document.querySelectorAll('.fc:not(.accepted)').forEach(fc => {
    fc.classList.add('accepted');
    const s = fc.querySelector('.fc-status');
    if (s) { s.textContent = 'Aceito'; s.classList.add('ok'); }
  });
}
function copyAll(btn) {
  btn.textContent = 'Copiado';
  btn.classList.add('copied');
  setTimeout(() => { btn.textContent = 'Copiar matéria'; btn.classList.remove('copied'); }, 2500);
}
</script>
