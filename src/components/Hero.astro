<script>
  // Hero tabs
  function heroTab(t: string) {
    document.querySelectorAll('.hero-tab').forEach(b => {
      const el = b as HTMLElement;
      el.classList.toggle('active', el.dataset.tab === t);
    });
    document.querySelectorAll('.hero-panel').forEach(p => p.classList.toggle('active', p.id === 'hero-' + t));
  }
  document.querySelectorAll('.hero-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const t = (tab as HTMLElement).dataset.tab;
      if (t) heroTab(t);
    });
  });

  // Hero field card accept
  function hFC(el: HTMLElement) {
    if (el.classList.contains('ok')) return;
    el.classList.add('ok');
    const s = el.querySelector('.h-fc-st') as HTMLElement | null;
    if (s) { s.textContent = 'Aceito'; s.className = 'h-fc-st done'; }
  }
  document.querySelectorAll('.hero-panel .h-fc:not(.ok)').forEach(fc => {
    fc.addEventListener('click', () => hFC(fc as HTMLElement));
  });

  // Trust card expand
  const hsTrust = document.getElementById('hsTrust');
  const hsTrustToggle = hsTrust?.querySelector('.hs-trust');
  if (hsTrust && hsTrustToggle) {
    hsTrustToggle.addEventListener('click', () => hsTrust.classList.toggle('open'));
  }

  // Hero accept all
  const heroAcceptAll = document.getElementById('heroAcceptAll');
  if (heroAcceptAll) {
    heroAcceptAll.addEventListener('click', () => {
      document.querySelectorAll('.hero-panel .h-fc:not(.ok)').forEach(f => {
        (f as HTMLElement).classList.add('ok');
        const s = f.querySelector('.h-fc-st') as HTMLElement | null;
        if (s) { s.textContent = '\u2713'; s.className = 'h-fc-st done'; }
      });
      (window as any).showToast?.('Tudo aceito');
    });
  }

  // Hero copy all
  const heroCopyAll = document.getElementById('heroCopyAll');
  if (heroCopyAll) {
    heroCopyAll.addEventListener('click', () => {
      (window as any).showToast?.('Materia copiada');
    });
  }

  // Tag toggles
  document.querySelectorAll('.hs-tag').forEach(tag => {
    tag.addEventListener('click', () => {
      const el = tag as HTMLElement;
      el.style.opacity = el.style.opacity === '0.4' ? '1' : '0.4';
    });
  });

  // Image actions
  document.querySelectorAll('.hs-da-yes').forEach(btn => {
    btn.addEventListener('click', () => {
      const img = btn.closest('.hs-img') as HTMLElement | null;
      if (img) img.style.borderColor = 'var(--p-green-b)';
      const actions = btn.parentElement;
      if (actions) actions.innerHTML = '<span style="font-size:9px;color:var(--p-green)">&#10003; Aceita</span>';
    });
  });
  document.querySelectorAll('.hs-da-no').forEach(btn => {
    btn.addEventListener('click', () => {
      const actions = btn.parentElement;
      if (actions) actions.innerHTML = '<span style="font-size:9px;color:var(--p-text-m)">&mdash; Original</span>';
    });
  });

  // Zone header collapse
  document.querySelectorAll('.h-zone-hd').forEach(hd => {
    hd.addEventListener('click', () => {
      hd.classList.toggle('collapsed');
      const next = hd.nextElementSibling as HTMLElement | null;
      if (next) next.style.display = hd.classList.contains('collapsed') ? 'none' : 'flex';
    });
  });
</script>
