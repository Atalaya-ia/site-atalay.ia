<!-- LGPD Cookie Consent Banner — Consent Mode v2 -->
<div class="cookie-banner" id="cookieBanner" role="dialog" aria-label="Consentimento de cookies">
  <div class="cookie-banner-content">
    <p>Usamos cookies para análise de tráfego e publicidade. Ao aceitar, você concorda com o uso de cookies conforme nossa <a href="/privacidade">Política de Privacidade</a>.</p>
    <div class="cookie-banner-actions">
      <button class="cookie-btn-accept" id="cookieAccept">Aceitar</button>
      <button class="cookie-btn-reject" id="cookieReject">Recusar</button>
    </div>
  </div>
</div>

<script>
  import { updateConsent } from '../utils/analytics';

  const CONSENT_KEY = 'atalayia_consent';

  function initBanner(): void {
    const banner = document.getElementById('cookieBanner');
    if (!banner) return;

    const stored = localStorage.getItem(CONSENT_KEY);

    if (stored !== null) {
      // User already made a choice — apply it silently
      updateConsent(stored === 'granted');
      return;
    }

    // Show banner for first-time visitors
    banner.classList.add('visible');

    document.getElementById('cookieAccept')?.addEventListener('click', () => {
      localStorage.setItem(CONSENT_KEY, 'granted');
      updateConsent(true);
      banner.classList.remove('visible');
    });

    document.getElementById('cookieReject')?.addEventListener('click', () => {
      localStorage.setItem(CONSENT_KEY, 'denied');
      updateConsent(false);
      banner.classList.remove('visible');
    });
  }

  initBanner();
</script>

<style is:global>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: var(--bg-card);
    border-top: 1px solid var(--border-l);
    padding: 16px 24px;
    transform: translateY(100%);
    transition: transform .3s ease;
  }

  .cookie-banner.visible {
    transform: translateY(0);
  }

  .cookie-banner-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .cookie-banner-content p {
    font-size: 13px;
    color: var(--text-s);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }

  .cookie-banner-content a {
    color: var(--orange);
    text-decoration: none;
    border-bottom: 1px solid rgba(192,106,66,.25);
  }

  .cookie-banner-content a:hover {
    border-bottom-color: var(--orange);
  }

  .cookie-banner-actions {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
  }

  .cookie-btn-accept {
    background: var(--orange);
    color: #fff;
    border: none;
    padding: 8px 20px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background .2s;
  }

  .cookie-btn-accept:hover {
    background: var(--orange-h);
  }

  .cookie-btn-reject {
    background: transparent;
    color: var(--text-s);
    border: 1px solid var(--border-l);
    padding: 8px 20px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: border-color .2s, color .2s;
  }

  .cookie-btn-reject:hover {
    border-color: var(--border-h);
    color: var(--text);
  }

  @media (max-width: 767px) {
    .cookie-banner-content {
      flex-direction: column;
      text-align: center;
      gap: 14px;
    }

    .cookie-banner-actions {
      width: 100%;
      justify-content: center;
    }
  }
</style>
